# Copier en .env (dev) ; définir ces variables dans le panel Infomaniak (prod).
PORT=4000

# Domaine(s) autorisé(s) pour CORS (séparés par des virgules). '*' = tous (dev uniquement).
CORS_ORIGIN=http://localhost:3000

# Auth admin (B02) — mot de passe fort + secret JWT long et aléatoire.
ADMIN_PASSWORD=change-me
JWT_SECRET=change-me-with-a-long-random-string

# Mot de passe MODO (accès restreint : inscriptions + tirage, pas d'édition). Vide = pas de modo.
MOD_PASSWORD=

# Clé de push du bot (B06). Laisser vide tant que B06 n'est pas activé.
PUSH_API_KEY=

# Dossier de stockage des JSON. Vide = <cwd>/data.
# En prod Infomaniak : pointer vers un dossier PERSISTANT hors de l'arbre déployé si possible.
DATA_DIR=

# Dossiers d'upload (vides = sous DATA_DIR). files = téléchargeables ; images = avatars/logos/bannières.
UPLOADS_DIR=
IMAGES_DIR=

# Webhook Discord (notifications d'inscription événement). Vide = pas de notification.
DISCORD_WEBHOOK_URL=

# Login Twitch des viewers (giveaways). Crée une app sur https://dev.twitch.tv/console
# Redirect OAuth à déclarer : <PUBLIC_API_URL>/api/auth/twitch/callback
# Vide = login Twitch désactivé (les giveaways refuseront alors les inscriptions).
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# URLs publiques (pour le redirect OAuth et le retour sur le site).
PUBLIC_API_URL=https://api.mystya.fr
PUBLIC_SITE_URL=https://mystya.fr
