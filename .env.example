# Copier en .env (dev) ; définir ces variables dans le panel Infomaniak (prod).
PORT=4000

# Domaine(s) autorisé(s) pour CORS (séparés par des virgules). '*' = tous (dev uniquement).
CORS_ORIGIN=http://localhost:3000

# Auth admin (B02) — mot de passe fort + secret JWT long et aléatoire.
ADMIN_PASSWORD=change-me
JWT_SECRET=change-me-with-a-long-random-string

# Clé de push du bot (B06). Laisser vide tant que B06 n'est pas activé.
PUSH_API_KEY=

# Dossier de stockage des JSON. Vide = <cwd>/data.
# En prod Infomaniak : pointer vers un dossier PERSISTANT hors de l'arbre déployé si possible.
DATA_DIR=
